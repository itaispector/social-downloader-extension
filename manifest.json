{
  "manifest_version": 3,
  "name": "Social Downloader",
  "version": "1.0.0",
  "description": "Download audio and video from YouTube, Facebook, Instagram, and TikTok.",
  "permissions": [
    "downloads",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.facebook.com/*",
    "*://*.instagram.com/*",
    "*://*.tiktok.com/*",
    "*://api.cobalt.tools/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["content-scripts/youtube.js"],
      "css": ["content-scripts/downloader.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.facebook.com/watch*",
        "*://*.facebook.com/*/videos/*",
        "*://*.facebook.com/reel/*",
        "*://*.facebook.com/video/*"
      ],
      "js": ["content-scripts/facebook.js"],
      "css": ["content-scripts/downloader.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.instagram.com/p/*",
        "*://*.instagram.com/reel/*",
        "*://*.instagram.com/tv/*"
      ],
      "js": ["content-scripts/instagram.js"],
      "css": ["content-scripts/downloader.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.tiktok.com/@*/video/*"],
      "js": ["content-scripts/tiktok.js"],
      "css": ["content-scripts/downloader.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["utils/extractor.js"],
      "matches": [
        "*://*.youtube.com/*",
        "*://*.facebook.com/*",
        "*://*.instagram.com/*",
        "*://*.tiktok.com/*"
      ]
    }
  ]
}
